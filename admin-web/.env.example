# ================================
# Admin Web 环境变量配置模板
# ================================
# 复制此文件为 .env.development 并填写实际值
# 警告：.env 文件包含敏感信息，切勿提交到版本控制系统

# ================================
# 开发服务器配置
# ================================
VITE_PORT=5173
VITE_API_URL=/api
VITE_API_PROXY_URL=http://localhost:3000
VITE_BASE_URL=/

# ================================
# 锁屏加密密钥
# ================================
# 用于加密锁屏密码，使用强随机字符串（至少 16 字符）
# 生成方式: openssl rand -base64 16
VITE_LOCK_ENCRYPT_KEY=your_lock_encrypt_key_here

# ================================
# 测试账户（仅开发环境）
# ================================
# 以下测试账户仅在开发环境显示，生产构建时自动移除
VITE_TEST_SUPER_USER=Super
VITE_TEST_SUPER_PASS=123456
VITE_TEST_ADMIN_USER=Admin
VITE_TEST_ADMIN_PASS=123456
VITE_TEST_USER=User
VITE_TEST_USER_PASS=123456
