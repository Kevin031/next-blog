# ================================
# Server 环境变量配置模板
# ================================
# 复制此文件为 .env 并填写实际值
# 警告：.env 文件包含敏感信息，切勿提交到版本控制系统

# ================================
# 数据库配置
# ================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWD=your_strong_password_here
DB_DATABASE=blog

# ================================
# 应用配置
# ================================
PORT=3000
NODE_ENV=development

# ================================
# JWT 配置
# ================================
# JWT 签名密钥（必须使用强随机字符串，至少 32 字符）
# 生成方式: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_chars_random_here

# ================================
# Redis 配置
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ================================
# 超级管理员配置（首次初始化）
# ================================
# 超级管理员用户名
SUPER_USERNAME=Super
# 超级管理员密码（留空则自动生成，运行 seed:super-admin 脚本时会显示）
SUPER_PASSWORD=
# 超级管理员邮箱
SUPER_EMAIL=admin@localhost
